{
  "users": {
    "name": "users",
    "columns": {
      "id": { "name": "id", "data_type": "uuid" },
      "name": { "name": "name", "data_type": "varchar(100)" },
      "email": { "name": "email", "data_type": "varchar(150)" }
    },
    "constraints": {
      "primary": ["id"],
      "unique": [["email"]]
    },
    "indexes": [["email"]]
  },
  "orders": {
    "name": "orders",
    "columns": {
      "id": { "name": "id", "data_type": "uuid" },
      "customer": { "name": "customer", "data_type": "varchar(100)" },
      "amount": { "name": "amount", "data_type": "numeric(10,2)" },
      "status": { "name": "status", "data_type": "varchar(20)", "default": "'pending'" }
    },
    "constraints": {
      "primary": ["id"]
    },
    "crdt": {
      "enabled": true
    }
  }
}
